    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/nprogress": "^0.2.3",
    "daisyui": "^5.5.23",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "nprogress": "^0.2.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.3",
