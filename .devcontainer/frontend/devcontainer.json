{
  "dockerComposeFile": [
    "../../compose.yaml",
    "../../compose.development.yaml",
    "../compose.dev.yaml"
  ],
  "service": "devcontainer-frontend",
  "workspaceFolder": "/workspace/frontend",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "shutdownAction": "none",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "svelte.svelte-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
